doctype html
head
  meta(charset='UTF-8')
  meta(name='viewport' content='width=device-width, initial-scale=1.0')
  title NyondoStock Admin Dashboard
  link(rel='stylesheet' href='https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css')
  link(rel='stylesheet' href='/css/admindashboard.css')
.sidebar
  .sidebar-branding
    i.fas.fa-hammer
    div
      h2 NyondoStock
      p Admin Portal
  nav.nav-menu
    a.active(href='#')
      i.fas.fa-th-large
      |  Dashboard
    a(href='#')
      i.fas.fa-boxes
      |  Inventory
    a(href='#')
      i.fas.fa-truck-loading
      |  Supplier Credit
    a(href='#')
      i.fas.fa-piggy-bank
      |  Deposit Scheme
    a(href='#')
      i.fas.fa-file-invoice-dollar
      |  Sales Reports
    a(href='#')
      i.fas.fa-users
      |  User Management
    a.logout(href='/logout')
      i.fas.fa-sign-out-alt
      |  Logout
.main-content
  header.top-bar
    .search-box
      i.fas.fa-search
      input(type='text' placeholder='Search stock or records...')
    .admin-profile
      span
        | Welcome, 
        strong Admin
      .profile-pic A
  .stats-grid
    .stat-card
      .stat-info
        p Total Stock Value
        h3 UGX 15,200,000
      i.fas.fa-warehouse
    .stat-card
      .stat-info
        p Total Deposits (Pool)
        h3 UGX 4,850,000
      i.fas.fa-coins
    .stat-card
      .stat-info
        p Supplier Debt
        h3.debt-text UGX 2,100,000
      i.fas.fa-exclamation-circle
  .recent-section
    .table-container
      h3 Recent Stock Updates
      table
        thead
          tr
            th Item Name
            th Category
            th Cost Price
            th Stock Level
            th Status
        tbody
          tr
            td Cement (Tororo)
            td Building
            td UGX 32,000
            td 150 Bags
            td
              span.status-ok In Stock
          tr
            td Iron Sheets (G28)
            td Roofing
            td UGX 45,000
            td 12 Items
            td
              span.status-low Low Stock
