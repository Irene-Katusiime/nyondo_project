doctype html
head
  meta(charset='UTF-8')
  meta(name='viewport' content='width=device-width, initial-scale=1.0')
  title Stock Management - Nyondo Stock
  link(rel='stylesheet' href='css/stockmanagement.css')
  link(rel='stylesheet' href='https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css')
.sidebar
  h2 Nyondo Stock
  a(href='#')
    i.fas.fa-th-large
    | Dashboard
  a.active(href='#')
    i.fas.fa-boxes
    | Stock
  a(href='#')
    i.fas.fa-shopping-cart
    | Sales
  a(href='#')
    i.fas.fa-truck
    | Suppliers
  a(href='#')
    i.fas.fa-wallet
    | Deposits
  a(href='#')
    i.fas.fa-chart-line
    | Reports
  a(href='#')
    i.fas.fa-sign-out-alt
    | Logout
.main
  header.header-section
    h1 Inventory &amp; Stock
  .stock-grid
    .card.form-card
      h2 Register New Stock
      form(action='/stockreg' method='post')
        .form-group
          label Item Name
          select(name='itemName' required='')
            option(value='') Select item name
            option(value='cement') Cement
            option(value='ironbars') Iron bars
            option(value='nails') Nails
            option(value='wheelbarrows') Wheelbarrows
            option(value='wiremesh') Wire mesh
            option(value='barbedwires') Barbed wires
            option(value='ironsheets') Iron sheets
        .form-group-row
          .form-group
            label Category
            select(name='category' required='')
              option(value='') Select category
              option(value='Roofing') Roofing
              option(value='Cement/Binding') Cement/Binding
              option(value='Plumbing') Plumbing
              option(value='Electrical') Electrical
          .form-group
            label Quantity
            input(type='number' name='quantity' placeholder='In Stock' required='')
        .form-group-row
          .form-group
            label Unit Price (UGX)
            input(type='number' name='unitprice' placeholder='Buying price' required='')
          .form-group
            label Selling Price (UGX)
            input#sellingprice(type='number' name='sellingprice' placeholder='Retail price' required='')
        .form-group-row  
          .form-group
            label Supplier Name
            input(type='text' name='suppliername' placeholder='Enter supplier name' required='')
          .form-group
            label Supplier Contact
            input(type='text' name='suppliercontact' placeholder='Enter supplier number' required='')
        button(type='submit') Update Inventory