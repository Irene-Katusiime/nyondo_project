doctype html
head
  meta(charset='UTF-8')
  meta(name='viewport' content='width=device-width, initial-scale=1.0')
  title Nyondo sales
  link(rel='stylesheet' href='css/sales.css')
  link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
  link(rel='stylesheet' href='https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css')
// Sidebar
.sidebar
  h2 Nyondo Stock
  a(href='#')
    i.fas.fa-th-large
    | Dashboard
  a(href='#')
    i.fas.fa-boxes
    | Stock
  a.active(href='#')
    i.fas.fa-shopping-cart
    | Sales
  a(href='#')
    i.fas.fa-truck
    | Suppliers
  a(href='#')
    i.fas.fa-wallet
    | Deposits
  a(href='#')
    i.fas.fa-chart-line
    | Reports
  a(href='#')
    i.fas.fa-sign-out-alt
    | Logout
// Main content
.main
  h1 Sales Management
  // Sales Table
  .table-container
    h2 Sales Records
    table
      tr
        th Item Name
        th Quantity
        th Unit Price (UGX)
        th Customer Name 
        th Customer Contact
        th Attendant
        th Date
        th Total
        th Actions 
      tbody
        each sale in sales 
          tr
            td= sale.itemname ? sale.itemname.itemName: ''
            td= sale.quantity 
            td= sale.unitprice 
            td= sale.customername
            td= sale.customercontact
            td= sale.attendant ? sale.attendant.fullname: 'attendant was deleted'
            td= new Date(sale.date).toLocaleDateString() 
            td= (sale.quantity*sale.unitprice).toLocaleString() 
              td
                .d-flex.gap-2
                  a.btn.btn-sm.btn-outline-warning(href=`/sale/edit/${sale._id}`)
                    i.fas.fa-edit
                  form.d-inline(action=`/delete/${sale._id}` method='post' onsubmit='return confirm("Are you sure you want to delete this item?");')
                    button.btn.btn-sm.btn-outline-danger(type='submit')
                      i.fas.fa-trash-alt
            if sales.length === 0
              tr
                td.text-center(colspan='9') No sales have been recorded yet.
                
            
            
